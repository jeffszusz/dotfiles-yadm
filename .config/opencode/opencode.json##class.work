{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "permission": {
    "edit": "ask"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"]
    }
  },
  "agent": {
    "plan": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "build": {
      "model": "github-copilot/claude-sonnet-4.6"
    }
  }
}
